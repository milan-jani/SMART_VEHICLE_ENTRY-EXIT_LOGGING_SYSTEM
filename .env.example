# Environment Configuration
# Copy this file to .env and update with your values

# API Configuration
API_BASE_URL=http://localhost:8000

# PlateRecognizer API
PLATE_RECOGNIZER_API_KEY_1=your_key_here
PLATE_RECOGNIZER_API_KEY_2=your_key_here
# Camera Configuration
DEFAULT_CAMERA_INDEX=0

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Azure Computer Vision (Phase 6 ID OCR)
# Get from: Azure Portal > Computer Vision > Keys and Endpoint
AZURE_CV_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com/
AZURE_CV_KEY=your_azure_key_here

# SMTP Configuration (for faculty notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
DEFAULT_SENDER="Smart Gate Admin <your_email@gmail.com>"
